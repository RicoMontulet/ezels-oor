# URL van de backend-endpoint die de opname als multipart/form-data ontvangt.
# Nog niet vastgesteld door het backend-team; laat leeg om lokaal te testen
# zonder backend (de verstuurknop meldt dan netjes dat versturen uitstaat).
BACKEND_URL=

# Substring om het opname-apparaat automatisch te herkennen in `arecord -l`.
AUDIO_DEVICE_HINT=Jabra

# Optioneel: forceer een ALSA-apparaat (bv. plughw:1,0) en sla autodetectie over.
AUDIO_DEVICE=

HOST=0.0.0.0
PORT=5000
