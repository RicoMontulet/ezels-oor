# Flask Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True
FLASK_ENV=development

# Server Configuration (use 0.0.0.0 only if you intentionally expose on LAN)
HOST=127.0.0.1
PORT=8080

# Local Recording App Configuration (5001 avoids macOS AirPlay on 5000)
RECORDING_APP_URL=http://localhost:5001

# Backend API Configuration (8082 if 8081 is already taken locally)
BACKEND_API_URL=http://localhost:8082
BACKEND_API_TIMEOUT=30

# Auto-refresh Configuration
AUTO_REFRESH_ENABLED=True
AUTO_REFRESH_INTERVAL=30

# Display Configuration
ITEMS_PER_PAGE=20
MAX_HISTORY_ITEMS=50
